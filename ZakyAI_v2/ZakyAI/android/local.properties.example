# انسخ هذا الملف إلى local.properties (والذي يجب ألا يُرفع إلى Git أبداً)
# ضع مفاتيحك الحقيقية هنا فقط. هذا الملف مضاف إلى .gitignore تلقائياً.

sdk.dir=/path/to/your/Android/sdk

GROQ_API_KEY=ضع_مفتاح_Groq_هنا
GROQ_BASE_URL=https://api.groq.com/openai/v1/

HUGGINGFACE_API_KEY=ضع_مفتاح_HuggingFace_هنا
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models/

CEREBRAS_API_KEY=ضع_مفتاح_Cerebras_هنا
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1/

OPENROUTER_API_KEY=ضع_مفتاح_OpenRouter_هنا
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/

# كلمة مرور المدير لا يجب تخزينها هنا كنص صريح في نسخة الإنتاج،
# استخدمها فقط للتطوير المحلي. في الإنتاج خزّن الـ hash في Firestore (انظر AdminViewModel.kt)
ADMIN_PASSWORD_DEV=غيّر_هذه_القيمة
